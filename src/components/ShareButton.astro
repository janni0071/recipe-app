---
export interface Props {
  title: string;
  label: string;
  copiedLabel: string;
}

const { title, label, copiedLabel } = Astro.props;
---

<button
  type="button"
  id="share-button"
  aria-label={label}
  data-title={title}
  data-copied-label={copiedLabel}
  class="flex-shrink-0 p-2 rounded-full bg-pink-100 hover:bg-pink-200 dark:bg-pink-900 dark:hover:bg-pink-800 text-pink-600 dark:text-pink-300 transition"
>
  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <circle cx="18" cy="5" r="2.5" stroke-width="2"></circle>
    <circle cx="6" cy="12" r="2.5" stroke-width="2"></circle>
    <circle cx="18" cy="19" r="2.5" stroke-width="2"></circle>
    <line x1="8.2" y1="10.7" x2="15.8" y2="6.3" stroke-width="2" stroke-linecap="round"></line>
    <line x1="8.2" y1="13.3" x2="15.8" y2="17.7" stroke-width="2" stroke-linecap="round"></line>
  </svg>
</button>
<span
  id="share-feedback"
  class="pointer-events-none fixed bottom-6 left-1/2 z-50 -translate-x-1/2 whitespace-nowrap rounded-lg bg-pink-100 text-pink-700 dark:bg-pink-950 dark:text-pink-300 px-4 py-2 text-sm opacity-0 transition-opacity duration-200 shadow-lg"
></span>

<script is:inline>
  // No define:vars here on purpose: this script's text is identical on
  // every recipe page, so Astro's ClientRouter only ever runs it once per
  // session and relies on this persistent astro:page-load listener to
  // rebind on every later navigation. Per-recipe data (title) lives in the
  // button's own data attributes, read fresh at click time, so it's never
  // stale even though the script body itself stops re-executing.
  function bindShareButton() {
    const button = document.getElementById('share-button');
    const feedback = document.getElementById('share-feedback');
    if (!button) return;

    button.addEventListener('click', async () => {
      const url = window.location.href;
      const title = button.dataset.title || document.title;

      if (navigator.share) {
        try {
          await navigator.share({ title, url });
        } catch {
          // Cancelled or failed — nothing to recover from.
        }
        return;
      }

      if (navigator.clipboard) {
        try {
          await navigator.clipboard.writeText(url);
          if (feedback) {
            feedback.textContent = button.dataset.copiedLabel || 'Link copied!';
            feedback.classList.remove('opacity-0');
            setTimeout(() => feedback.classList.add('opacity-0'), 1500);
          }
        } catch {
          // Clipboard write failed — no further fallback available.
        }
      }
    });
  }

  document.addEventListener('astro:page-load', bindShareButton);
</script>
