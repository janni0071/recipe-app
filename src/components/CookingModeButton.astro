---
export interface Props {
  label: string;
  shortLabel: string;
  exitLabel: string;
}

const { label, shortLabel, exitLabel } = Astro.props;
---

<button
  type="button"
  id="cooking-mode-button"
  data-active="false"
  data-label={label}
  data-exit-label={exitLabel}
  aria-label={label}
  aria-pressed="false"
  class="group flex-shrink-0 ml-auto inline-flex items-center px-2.5 sm:px-5 py-3 rounded-full bg-pink-200 hover:bg-pink-300 active:bg-pink-400 dark:bg-pink-800 dark:hover:bg-pink-700 text-pink-800 dark:text-pink-100 font-semibold leading-none transition cooking-mode:bg-linear-to-r cooking-mode:from-orange-500 cooking-mode:to-rose-600 cooking-mode:hover:brightness-110 cooking-mode:active:brightness-95 cooking-mode:text-white dark:cooking-mode:from-orange-400 dark:cooking-mode:to-rose-400"
>
  <svg class="cooking-mode-button-flame w-5 h-5 group-data-[active=true]:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path
      d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    ></path>
  </svg>
  <svg class="hidden w-5 h-5 group-data-[active=true]:block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path d="M6 6l12 12M18 6L6 18" stroke-width="2" stroke-linecap="round"></path>
  </svg>
  {/* Full label pushes the 5-button header row past the available width on
  narrow phones, so below sm: it's swapped for a short one instead of being
  dropped entirely — a bare icon blended in with the other plain icon
  buttons and lost the "tap me" prominence the text was added for. The exit
  label stays untouched since by then it's the only button left in the row.
  Spacing to the icon is margin on the text itself (not a flex `gap` on the
  button) so the icon stays centered when a label is hidden — a gap would
  still reserve space for this span even with no visible content.
  Swapped on `cooking-mode-layout`, not `data-active` directly — these two
  labels differ in width, and swapping instantly (mid-transition, before the
  sibling header buttons are hidden) can tip the still-crowded button row
  into an extra flex-wrap line, changing the page's height while the wipe is
  still in flight. Deferring it alongside everything else that affects
  height (see global.css/CookingModeButton.astro) avoids that. The icon
  swap above stays on `data-active` since two fixed 20×20 icons swapping has
  no layout impact and needs to track the wipe's reveal point instantly. */}
  <span class="cooking-mode-layout:hidden">
    <span class="sm:hidden ml-1.5">{shortLabel}</span>
    <span class="hidden sm:inline ml-2">{label}</span>
  </span>
  <span class="hidden cooking-mode-layout:block ml-2">{exitLabel}</span>
</button>

<script is:inline>
  // Generic, identical content on every recipe page — same dedup-safe
  // astro:page-load pattern as ShareButton/PrintButton. Labels live in data
  // attributes read fresh at toggle time, so nothing here goes stale.

  // setActive/enterCookingMode/exitCookingMode live at module scope (rather
  // than closing over a single page-load's button) because the
  // keydown/astro:before-swap listeners below are only ever bound once
  // (window.__cookingModeBound guards against piling up a listener per
  // navigation). If they closed over one navigation's button, every later
  // navigation's exit-via-Escape would update a detached button instead of
  // whatever button is actually live on screen.
  function setActive(active) {
    const button = document.getElementById('cooking-mode-button');
    if (!button) return;
    button.dataset.active = String(active);
    button.setAttribute('aria-pressed', String(active));
    button.setAttribute('aria-label', active ? button.dataset.exitLabel : button.dataset.label);
    document.documentElement.classList.toggle('cooking-mode', active);
  }

  // Separate from setActive(): this toggles `cooking-mode-layout`, the variant
  // that hides/shows the header, footer, tags row, similar-recipes section,
  // the inline favorite/share/print row, AND (via the cookingmodechange event
  // dispatched here) StepList's one-step-at-a-time collapse, its per-step
  // timer button/progress bar/prev-next controls, and the ingredient list's
  // font-size bump — every mutation that changes the page's height. Kept
  // apart from the `cooking-mode` class above (which still toggles instantly,
  // for the colors/text-fill right under the tap) so the click handler below
  // can apply it only once the wipe overlay has fully covered the screen —
  // see the comment on the cover/reveal animations further down.
  function setCookingModeLayout(active) {
    document.documentElement.classList.toggle('cooking-mode-layout', active);
    document.dispatchEvent(new CustomEvent('cookingmodechange', { detail: { active } }));
  }

  async function releaseWakeLock() {
    if (window.__cookingModeWakeLock) {
      try {
        await window.__cookingModeWakeLock.release();
      } catch {
        // Already released — nothing to recover from.
      }
      window.__cookingModeWakeLock = null;
    }
  }

  async function requestWakeLock() {
    // Unsupported in some browsers (e.g. older iOS Safari) — cooking mode
    // still works, the screen just won't be kept on there.
    if (!('wakeLock' in navigator)) return;
    try {
      window.__cookingModeWakeLock = await navigator.wakeLock.request('screen');
    } catch {
      // Denied (e.g. low battery saver) — nothing further to do.
    }
  }

  async function enterCookingMode() {
    setActive(true);
    setCookingModeLayout(true);
    requestWakeLock();
    // iOS Safari has no Fullscreen API for arbitrary elements, so this is
    // a progressive enhancement on top of the CSS-driven immersive layout
    // that setActive() above already switched on for every browser.
    if (document.documentElement.requestFullscreen) {
      try {
        await document.documentElement.requestFullscreen();
      } catch {
        // Denied/unsupported — the CSS layout and wake lock still apply.
      }
    }
  }

  async function exitCookingMode() {
    setActive(false);
    setCookingModeLayout(false);
    releaseWakeLock();
    if (document.fullscreenElement) {
      try {
        await document.exitFullscreen();
      } catch {
        // Nothing left to recover from.
      }
    }
  }

  function bindCookingModeButton() {
    const button = document.getElementById('cooking-mode-button');
    if (!button) return;

    // Tracks this button's own in-flight wipe so a second click landing
    // before the previous one's cleanup ran can tear it down first, rather
    // than piling up overlapping overlays/glows/sparks.
    let pendingOverlay = null;
    let pendingGlow = null;
    let pendingSparks = null;
    let pendingAnimations = [];

    if (!window.__cookingModeBound) {
      window.__cookingModeBound = true;

      // Fullscreen gets exited by plenty of things besides a deliberate
      // "leave cooking mode" action — screen lock, switching apps, a
      // phone's hardware back button — and whether the document even
      // reports itself as hidden when that happens is inconsistent across
      // browsers (Brave doesn't mark it hidden on screen lock the way
      // Chrome/Firefox do, so that can't be used to tell the cases apart
      // reliably). So losing fullscreen no longer ends cooking mode by
      // itself: the wake lock and any running timers stay alive, and the
      // still-visible exit button (or Escape, below) is how you actually
      // leave.
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && document.documentElement.classList.contains('cooking-mode')) {
          exitCookingMode();
        }
      });

      // The Wake Lock is auto-released by the browser whenever the page
      // loses visibility (tab switch, screen lock) — reacquire it once
      // we're back, but only if cooking mode is still meant to be on.
      // Fullscreen may have been force-exited too (see above); best-effort
      // re-request it, though most browsers require a fresh user gesture
      // to grant that, so this silently no-ops there.
      document.addEventListener('visibilitychange', () => {
        if (document.visibilityState === 'visible' && document.documentElement.classList.contains('cooking-mode')) {
          requestWakeLock();
          if (!document.fullscreenElement && document.documentElement.requestFullscreen) {
            document.documentElement.requestFullscreen().catch(() => {});
          }
        }
      });

      // Leaving the recipe page entirely (SPA navigation) shouldn't carry
      // cooking mode into whatever page comes next.
      document.addEventListener('astro:before-swap', () => {
        if (document.documentElement.classList.contains('cooking-mode')) {
          exitCookingMode();
        }
      });
    }

    button.addEventListener('click', (e) => {
      const activating = button.dataset.active !== 'true';

      // Escape/before-swap/visibilitychange reuse enter/exitCookingMode
      // directly (no click coordinates, and a multi-hundred-ms wipe has no
      // business delaying an "I'm leaving" or background re-sync). The
      // button click is the one place we have a pointer position to anchor
      // the reveal on, so only it gets the animated treatment.
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (reduceMotion) {
        if (activating) enterCookingMode();
        else exitCookingMode();
        return;
      }

      // A second click landing before the previous wipe's cleanup ran tears
      // that one down first. Cancelling its animations rejects their
      // `finished` promises (caught further down), so the older chain's
      // mutate/reveal/cleanup steps never run, and its elements are gone
      // before the new ones go up.
      pendingAnimations.forEach((anim) => anim.cancel());
      pendingAnimations = [];
      pendingOverlay?.remove();
      pendingGlow?.remove();
      pendingSparks?.remove();

      const root = document.documentElement;
      const x = e.clientX;
      const y = e.clientY;
      const endRadius = Math.hypot(Math.max(x, innerWidth - x), Math.max(y, innerHeight - y));

      // The wipe is a plain WAAPI animation on an ordinary fixed `<div>` —
      // it grows from the tap point to fully cover the screen with an
      // opaque flame-gradient disc (the "cover" animation below); once
      // nothing of the page is visible, every mutation that changes the
      // page's content or height happens hidden behind it (see
      // coverAnim.finished below); then the same disc shrinks back to a
      // point to reveal the result (the "reveal" animation).
      //
      // This used to be built on document.startViewTransition(), purely as
      // a way to get a "new state" pseudo-element to clip-path-animate (the
      // crossfade ::view-transition-old/new(root) would normally do on its
      // own was always disabled — see the now-removed rules in global.css).
      // Real devices were silently aborting that mid-flight: their browser
      // UI chrome (the address/toolbar bar) reacts to the very tap that
      // starts the transition, firing a resize the page can neither detect
      // nor prevent, and the View Transitions spec treats any resize during
      // an active transition as automatic grounds to cancel it — confirmed
      // across several rounds of real-device retesting and CSS fixes that
      // ruled out every other cause, including reproducing it with
      // document.documentElement.scrollHeight provably unchanged for the
      // whole transition. An ordinary animated element has nothing to do
      // with view transitions and is never subject to that abort, and is
      // far cheaper than snapshotting the page into an image to fake the
      // same effect, which is the only reason a screenshot-based approach
      // (e.g. html2canvas) was ever a candidate.
      const overlay = document.createElement('div');
      overlay.style.cssText =
        `position:fixed;inset:0;pointer-events:none;z-index:9999;` +
        `clip-path:circle(0px at ${x}px ${y}px);` +
        `background:radial-gradient(circle at ${x}px ${y}px, #fff7e0 0%, #fde68a 18%, #f97316 45%, #be123c 70%, #2e0a08 100%);`;
      document.body.appendChild(overlay);

      // The glow ring and embers below are unchanged from the original
      // view-transition build (same gradients/canvas drawing, same
      // endRadius-lockstep scale curve) — only how they're driven changed.
      // They used to animate ::view-transition-new(...) pseudo-elements
      // (the only way to layer something above the transition's own
      // snapshot tree); now they're plain fixed-position elements, stacked
      // above the overlay by z-index and animated directly, since there's
      // no pseudo-element tree to target any more.
      const ringSize = 260;
      // Both cooking-mode backdrops (light: amber/orange/rose pastels, dark:
      // near-black with a rose tint) are themselves warm-toned, so a glow
      // built only from mid-tone oranges/roses blends straight into either
      // one. Contrast comes from a hot core next to a much darker rim —
      // the core pops against the dark backdrop, the rim pops against the
      // light one. The rim is a low-alpha ember brown rather than a flat
      // near-black: a fully opaque dark stop right next to the transparent
      // edge reads as a solid ring outline, not fire, so it fades out
      // gradually instead of snapping dark. The colored stops are bunched
      // up near the outer edge (80%+) rather than spread from 65%, so the
      // band itself reads as a slim ring instead of a wide glowing disc.
      const glow = document.createElement('div');
      glow.style.cssText = `position:fixed;left:${x}px;top:${y}px;width:${ringSize}px;height:${ringSize}px;border-radius:50%;pointer-events:none;filter:blur(3px);z-index:10000;transform:translate(-50%,-50%) scale(0);background:radial-gradient(circle farthest-side, transparent 80%, rgba(255,244,214,0.95) 90%, rgba(254,240,138,1) 93%, rgba(249,115,22,1) 95.5%, rgba(190,18,60,0.9) 97.5%, rgba(76,16,12,0.5) 99%, transparent 100%);`;
      document.body.appendChild(glow);

      // A scatter of embers riding the wipe's own advancing edge — baked
      // into one small canvas rather than drawn as N separate elements, and
      // animated with the exact same endRadius-lockstep scale curve as the
      // glow ring (see sparkMaxScale below) so they expand in step with the
      // wipe/ring rather than on their own independent timeline. The two
      // together read as the flame front throwing off embers as it sweeps
      // through the page, rather than a single burst flung from the button.
      const sparkSize = 280;
      const sparkCount = 32;
      const sparks = document.createElement('canvas');
      sparks.width = sparkSize;
      sparks.height = sparkSize;
      sparks.style.cssText = `position:fixed;left:${x}px;top:${y}px;width:${sparkSize}px;height:${sparkSize}px;pointer-events:none;z-index:10001;transform:translate(-50%,-50%) scale(0);`;
      // Drawn once into the canvas's own small pixel space rather than
      // animated per frame — each spark's distance-from-center is baked
      // in at a random fraction of the canvas's own radius, so scaling
      // the whole canvas up later (see sparkMaxScale) carries every spark
      // outward together while preserving their relative distances, the
      // same "dots on an expanding sheet" trick the ring above relies on.
      // Bunched into a tight band near the canvas's own edge (0.68-0.95,
      // rather than spread all the way back to the center) so that once
      // stretched by the same lockstep scale as the ring, they sit right
      // around the ring's own edge instead of trailing all the way back
      // to the click point — embers thrown off the front, not left
      // behind at the source.
      const sparkCtx = sparks.getContext('2d');
      const sparkCenter = sparkSize / 2;
      for (let i = 0; i < sparkCount; i++) {
        const angle = Math.random() * Math.PI * 2;
        const dist = sparkCenter * (0.68 + Math.random() * 0.27);
        const sx = sparkCenter + Math.cos(angle) * dist;
        const sy = sparkCenter + Math.sin(angle) * dist;
        const r = 0.8 + Math.random() * 1.2;
        // Percentage-based gradient stops on a radius this small put the
        // dark rim band under a pixel wide (e.g. 8% of a 2px radius),
        // invisible regardless of how much the canvas is later stretched
        // — confirmed by screenshotting a first attempt that used plain
        // percentage stops on `r` directly: every spark just read as a
        // soft blob, no rim. haloR adds a fixed ~1px ring beyond the
        // bright core instead, so the rim band's actual pixel width stays
        // roughly constant across every spark's size, not shrinking along
        // with the smaller ones. (Scaled down again alongside the smaller
        // core radius above — a wider fixed offset would swallow cores
        // this small entirely.)
        const haloR = r + 1;
        const coreEdge = r / haloR;
        // Same hot-core-vs-ember-rim contrast logic as the glow ring:
        // most sparks are the mid-tone orange that needs the dark rim to
        // read against the light backdrop, a minority are near-white so
        // a few pop against the dark backdrop too.
        const hot = Math.random() < 0.35;
        const grad = sparkCtx.createRadialGradient(sx, sy, 0, sx, sy, haloR);
        if (hot) {
          grad.addColorStop(0, 'rgba(255,250,230,1)');
          grad.addColorStop(coreEdge * 0.55, 'rgba(254,240,138,0.95)');
          grad.addColorStop(coreEdge, 'rgba(249,115,22,0.9)');
          grad.addColorStop(coreEdge + (1 - coreEdge) * 0.45, 'rgba(120,30,15,0.6)');
          grad.addColorStop(1, 'rgba(120,30,15,0)');
        } else {
          grad.addColorStop(0, 'rgba(255,237,160,1)');
          grad.addColorStop(coreEdge * 0.55, 'rgba(249,115,22,0.9)');
          grad.addColorStop(coreEdge, 'rgba(190,18,60,0.85)');
          grad.addColorStop(coreEdge + (1 - coreEdge) * 0.45, 'rgba(76,16,12,0.6)');
          grad.addColorStop(1, 'rgba(76,16,12,0)');
        }
        sparkCtx.fillStyle = grad;
        sparkCtx.beginPath();
        sparkCtx.arc(sx, sy, haloR, 0, Math.PI * 2);
        sparkCtx.fill();
      }
      document.body.appendChild(sparks);

      pendingOverlay = overlay;
      pendingGlow = glow;
      pendingSparks = sparks;

      // Only the `cooking-mode` class toggle (colors/text-fill/icons) goes
      // out right away — it's directly under the tap, where the overlay's
      // own growth covers it again almost instantly, so there's nothing to
      // see jump. Everything else (see setCookingModeLayout above) waits
      // for coverAnim.finished below, once the overlay is fully opaque.
      setActive(activating);

      const coverDuration = 600;
      const revealDuration = 450;
      const coverAnim = overlay.animate(
        { clipPath: [`circle(0px at ${x}px ${y}px)`, `circle(${endRadius}px at ${x}px ${y}px)`] },
        { duration: coverDuration, easing: 'ease-in', fill: 'forwards' }
      );
      // maxScale stretches the ring's small fixed-size raster so its outer
      // edge reaches endRadius — the same target the overlay's own
      // clip-path animates to, over the same 600ms (the 2/3 offset below,
      // of this animation's 900ms duration). Scale and clip-path radius
      // both follow an 'ease-in' curve to the same target over the same
      // duration, so the ring's edge and the cover's edge land on the same
      // radius at every instant, not just at the end. The extra *1.08 is a
      // small overshoot past that shared target the ring settles back from
      // while it fades out, after the cover animation has already finished
      // and the page is mutating behind it.
      const maxScale = ((endRadius * 2) / ringSize) * 1.08;
      const glowScaleAnim = glow.animate(
        [
          // A keyframe's `easing` governs the segment FROM it to the next
          // one, not the segment leading into it — so 'ease-in' belongs on
          // keyframe 0 (covers 0→2/3, the growth) and 'ease-out' on
          // keyframe 1 (covers 2/3→1, the tail), not the other way round.
          { transform: 'translate(-50%,-50%) scale(0)', easing: 'ease-in' },
          { transform: `translate(-50%,-50%) scale(${maxScale / 1.08})`, offset: 2 / 3, easing: 'ease-out' },
          { transform: `translate(-50%,-50%) scale(${maxScale})` },
        ],
        { duration: 900, fill: 'forwards' }
      );
      // Opacity gets its own timeline rather than riding the scale curve
      // above — ramping to full brightness almost immediately and holding
      // it there means the ring is already lit up while it's still small
      // and near the click point, fading out only at the very end
      // regardless of how far it's grown by then (an 'ease-in' scale stays
      // dim for most of its run, which left the ring bright only once
      // mostly off-screen at larger click-to-corner distances).
      const glowOpacityAnim = glow.animate(
        [
          { opacity: 0 },
          { opacity: 1, offset: 0.18 },
          { opacity: 1, offset: 0.7, easing: 'ease-out' },
          { opacity: 0 },
        ],
        { duration: 900, fill: 'forwards' }
      );
      // Same endRadius-lockstep curve as the glow ring's maxScale above —
      // same target, same 'ease-in' over the same 600ms — so the embers'
      // band (baked at 0.68-0.95 of the canvas's own radius, see the
      // sparkCount loop above) expands in step with the cover/ring instead
      // of drifting outward on its own independent schedule.
      const sparkMaxScale = ((endRadius * 2) / sparkSize) * 1.08;
      const sparkScaleAnim = sparks.animate(
        [
          { transform: 'translate(-50%,-50%) scale(0)', easing: 'ease-in' },
          { transform: `translate(-50%,-50%) scale(${sparkMaxScale / 1.08})`, offset: 2 / 3, easing: 'ease-out' },
          { transform: `translate(-50%,-50%) scale(${sparkMaxScale})` },
        ],
        { duration: 900, fill: 'forwards' }
      );
      // Faster ramp-up and a later, more gradual fade than the glow ring —
      // sparks are small enough that a slow fade reads as "drifting out"
      // rather than "still here", giving the embers a chance to feel like
      // they're floating/dying out after the main flash instead of popping
      // off all at once with everything else.
      const sparkOpacityAnim = sparks.animate(
        [
          { opacity: 0 },
          { opacity: 1, offset: 0.08 },
          { opacity: 1, offset: 0.45, easing: 'ease-out' },
          { opacity: 0 },
        ],
        { duration: 1000, fill: 'forwards' }
      );
      pendingAnimations = [coverAnim, glowScaleAnim, glowOpacityAnim, sparkScaleAnim, sparkOpacityAnim];

      Promise.all([glowScaleAnim.finished, glowOpacityAnim.finished])
        .then(() => {
          if (pendingGlow === glow) pendingGlow = null;
          glow.remove();
        })
        .catch(() => {
          // Cancelled by a newer click (see above) — that click already
          // removed this glow directly.
        });
      Promise.all([sparkScaleAnim.finished, sparkOpacityAnim.finished])
        .then(() => {
          if (pendingSparks === sparks) pendingSparks = null;
          sparks.remove();
        })
        .catch(() => {});

      coverAnim.finished
        .then(() => {
          // A later click may have already cancelled this one and started
          // its own — don't mutate state or reveal on its behalf.
          if (pendingOverlay !== overlay) return;

          setCookingModeLayout(activating);
          if (activating) {
            requestWakeLock();
            if (root.requestFullscreen) root.requestFullscreen().catch(() => {});
          } else {
            releaseWakeLock();
            if (document.fullscreenElement) document.exitFullscreen().catch(() => {});
          }

          // A brief overexposed flash as the new content is revealed, like
          // the wipe is briefly catching light.
          root.animate(
            { filter: ['brightness(1.7) saturate(1.6)', 'brightness(1) saturate(1)'] },
            { duration: 320, easing: 'ease-out' }
          );
          const revealAnim = overlay.animate(
            { clipPath: [`circle(${endRadius}px at ${x}px ${y}px)`, `circle(0px at ${x}px ${y}px)`] },
            { duration: revealDuration, easing: 'ease-out', fill: 'forwards' }
          );
          pendingAnimations.push(revealAnim);
          revealAnim.finished
            .then(() => {
              if (pendingOverlay === overlay) pendingOverlay = null;
              overlay.remove();
            })
            .catch(() => {});
        })
        .catch(() => {
          // Cancelled by a newer click (see above) — that click's own
          // chain owns the mutation/reveal/cleanup; nothing further to do.
        });
    });
  }

  document.addEventListener('astro:page-load', bindCookingModeButton);
</script>
