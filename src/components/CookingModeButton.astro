---
export interface Props {
  label: string;
  exitLabel: string;
}

const { label, exitLabel } = Astro.props;
---

<button
  type="button"
  id="cooking-mode-button"
  data-active="false"
  data-label={label}
  data-exit-label={exitLabel}
  aria-label={label}
  aria-pressed="false"
  class="group flex-shrink-0 ml-auto inline-flex items-center gap-2 px-5 py-3 rounded-full bg-pink-200 hover:bg-pink-300 active:bg-pink-400 dark:bg-pink-800 dark:hover:bg-pink-700 text-pink-800 dark:text-pink-100 font-semibold leading-none transition"
>
  <svg class="w-5 h-5 group-data-[active=true]:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path
      d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    ></path>
  </svg>
  <svg class="hidden w-5 h-5 group-data-[active=true]:block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path d="M6 6l12 12M18 6L6 18" stroke-width="2" stroke-linecap="round"></path>
  </svg>
  <span class="group-data-[active=true]:hidden">{label}</span>
  <span class="hidden group-data-[active=true]:block">{exitLabel}</span>
</button>

<script is:inline>
  // Generic, identical content on every recipe page — same dedup-safe
  // astro:page-load pattern as ShareButton/PrintButton. Labels live in data
  // attributes read fresh at toggle time, so nothing here goes stale.
  //
  // setActive/enterCookingMode/exitCookingMode live at module scope (rather
  // than closing over a single page-load's button) because the
  // keydown/astro:before-swap listeners below are only ever bound once
  // (window.__cookingModeBound guards against piling up a listener per
  // navigation). If they closed over one navigation's button, every later
  // navigation's exit-via-Escape would update a detached button instead of
  // whatever button is actually live on screen.
  function setActive(active) {
    const button = document.getElementById('cooking-mode-button');
    if (!button) return;
    button.dataset.active = String(active);
    button.setAttribute('aria-pressed', String(active));
    button.setAttribute('aria-label', active ? button.dataset.exitLabel : button.dataset.label);
    document.documentElement.classList.toggle('cooking-mode', active);
    document.dispatchEvent(new CustomEvent('cookingmodechange', { detail: { active } }));
  }

  async function releaseWakeLock() {
    if (window.__cookingModeWakeLock) {
      try {
        await window.__cookingModeWakeLock.release();
      } catch {
        // Already released — nothing to recover from.
      }
      window.__cookingModeWakeLock = null;
    }
  }

  async function requestWakeLock() {
    // Unsupported in some browsers (e.g. older iOS Safari) — cooking mode
    // still works, the screen just won't be kept on there.
    if (!('wakeLock' in navigator)) return;
    try {
      window.__cookingModeWakeLock = await navigator.wakeLock.request('screen');
    } catch {
      // Denied (e.g. low battery saver) — nothing further to do.
    }
  }

  async function enterCookingMode() {
    setActive(true);
    requestWakeLock();
    // iOS Safari has no Fullscreen API for arbitrary elements, so this is
    // a progressive enhancement on top of the CSS-driven immersive layout
    // that setActive() above already switched on for every browser.
    if (document.documentElement.requestFullscreen) {
      try {
        await document.documentElement.requestFullscreen();
      } catch {
        // Denied/unsupported — the CSS layout and wake lock still apply.
      }
    }
  }

  async function exitCookingMode() {
    setActive(false);
    releaseWakeLock();
    if (document.fullscreenElement) {
      try {
        await document.exitFullscreen();
      } catch {
        // Nothing left to recover from.
      }
    }
  }

  function bindCookingModeButton() {
    const button = document.getElementById('cooking-mode-button');
    if (!button) return;

    if (!window.__cookingModeBound) {
      window.__cookingModeBound = true;

      // Fullscreen gets exited by plenty of things besides a deliberate
      // "leave cooking mode" action — screen lock, switching apps, a
      // phone's hardware back button — and whether the document even
      // reports itself as hidden when that happens is inconsistent across
      // browsers (Brave doesn't mark it hidden on screen lock the way
      // Chrome/Firefox do, so that can't be used to tell the cases apart
      // reliably). So losing fullscreen no longer ends cooking mode by
      // itself: the wake lock and any running timers stay alive, and the
      // still-visible exit button (or Escape, below) is how you actually
      // leave.
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && document.documentElement.classList.contains('cooking-mode')) {
          exitCookingMode();
        }
      });

      // The Wake Lock is auto-released by the browser whenever the page
      // loses visibility (tab switch, screen lock) — reacquire it once
      // we're back, but only if cooking mode is still meant to be on.
      // Fullscreen may have been force-exited too (see above); best-effort
      // re-request it, though most browsers require a fresh user gesture
      // to grant that, so this silently no-ops there.
      document.addEventListener('visibilitychange', () => {
        if (document.visibilityState === 'visible' && document.documentElement.classList.contains('cooking-mode')) {
          requestWakeLock();
          if (!document.fullscreenElement && document.documentElement.requestFullscreen) {
            document.documentElement.requestFullscreen().catch(() => {});
          }
        }
      });

      // Leaving the recipe page entirely (SPA navigation) shouldn't carry
      // cooking mode into whatever page comes next.
      document.addEventListener('astro:before-swap', () => {
        if (document.documentElement.classList.contains('cooking-mode')) {
          exitCookingMode();
        }
      });
    }

    button.addEventListener('click', () => {
      if (button.dataset.active === 'true') {
        exitCookingMode();
      } else {
        enterCookingMode();
      }
    });
  }

  document.addEventListener('astro:page-load', bindCookingModeButton);
</script>
