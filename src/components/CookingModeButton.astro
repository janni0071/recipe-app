---
export interface Props {
  label: string;
  shortLabel: string;
  exitLabel: string;
}

const { label, shortLabel, exitLabel } = Astro.props;
---

<button
  type="button"
  id="cooking-mode-button"
  data-active="false"
  data-label={label}
  data-exit-label={exitLabel}
  aria-label={label}
  aria-pressed="false"
  class="group flex-shrink-0 ml-auto inline-flex items-center px-2.5 sm:px-5 py-3 rounded-full bg-pink-200 hover:bg-pink-300 active:bg-pink-400 dark:bg-pink-800 dark:hover:bg-pink-700 text-pink-800 dark:text-pink-100 font-semibold leading-none transition cooking-mode:bg-linear-to-r cooking-mode:from-orange-500 cooking-mode:to-rose-600 cooking-mode:hover:brightness-110 cooking-mode:active:brightness-95 cooking-mode:text-white dark:cooking-mode:from-orange-400 dark:cooking-mode:to-rose-400"
>
  <svg class="w-5 h-5 group-data-[active=true]:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path
      d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    ></path>
  </svg>
  <svg class="hidden w-5 h-5 group-data-[active=true]:block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path d="M6 6l12 12M18 6L6 18" stroke-width="2" stroke-linecap="round"></path>
  </svg>
  {/* Full label pushes the 5-button header row past the available width on
  narrow phones, so below sm: it's swapped for a short one instead of being
  dropped entirely — a bare icon blended in with the other plain icon
  buttons and lost the "tap me" prominence the text was added for. The exit
  label stays untouched since by then it's the only button left in the row.
  Spacing to the icon is margin on the text itself (not a flex `gap` on the
  button) so the icon stays centered when a label is hidden — a gap would
  still reserve space for this span even with no visible content. */}
  <span class="group-data-[active=true]:hidden">
    <span class="sm:hidden ml-1.5">{shortLabel}</span>
    <span class="hidden sm:inline ml-2">{label}</span>
  </span>
  <span class="hidden group-data-[active=true]:block ml-2">{exitLabel}</span>
</button>

<script is:inline>
  // Generic, identical content on every recipe page — same dedup-safe
  // astro:page-load pattern as ShareButton/PrintButton. Labels live in data
  // attributes read fresh at toggle time, so nothing here goes stale.
  //
  // setActive/enterCookingMode/exitCookingMode live at module scope (rather
  // than closing over a single page-load's button) because the
  // keydown/astro:before-swap listeners below are only ever bound once
  // (window.__cookingModeBound guards against piling up a listener per
  // navigation). If they closed over one navigation's button, every later
  // navigation's exit-via-Escape would update a detached button instead of
  // whatever button is actually live on screen.
  function setActive(active) {
    const button = document.getElementById('cooking-mode-button');
    if (!button) return;
    button.dataset.active = String(active);
    button.setAttribute('aria-pressed', String(active));
    button.setAttribute('aria-label', active ? button.dataset.exitLabel : button.dataset.label);
    document.documentElement.classList.toggle('cooking-mode', active);
    document.dispatchEvent(new CustomEvent('cookingmodechange', { detail: { active } }));
  }

  async function releaseWakeLock() {
    if (window.__cookingModeWakeLock) {
      try {
        await window.__cookingModeWakeLock.release();
      } catch {
        // Already released — nothing to recover from.
      }
      window.__cookingModeWakeLock = null;
    }
  }

  async function requestWakeLock() {
    // Unsupported in some browsers (e.g. older iOS Safari) — cooking mode
    // still works, the screen just won't be kept on there.
    if (!('wakeLock' in navigator)) return;
    try {
      window.__cookingModeWakeLock = await navigator.wakeLock.request('screen');
    } catch {
      // Denied (e.g. low battery saver) — nothing further to do.
    }
  }

  async function enterCookingMode() {
    setActive(true);
    requestWakeLock();
    // iOS Safari has no Fullscreen API for arbitrary elements, so this is
    // a progressive enhancement on top of the CSS-driven immersive layout
    // that setActive() above already switched on for every browser.
    if (document.documentElement.requestFullscreen) {
      try {
        await document.documentElement.requestFullscreen();
      } catch {
        // Denied/unsupported — the CSS layout and wake lock still apply.
      }
    }
  }

  async function exitCookingMode() {
    setActive(false);
    releaseWakeLock();
    if (document.fullscreenElement) {
      try {
        await document.exitFullscreen();
      } catch {
        // Nothing left to recover from.
      }
    }
  }

  function bindCookingModeButton() {
    const button = document.getElementById('cooking-mode-button');
    if (!button) return;

    // Tracks this button's own in-flight wipe so a second click landing
    // before the previous one's cleanup ran can tear it down first. Without
    // this, the new click's glow div gets appended — carrying the same
    // view-transition-name as the still-present previous one — before that
    // older glow is removed, which the browser treats as a duplicate name
    // and responds to by silently skipping the whole transition: no error,
    // just no wipe and no glow at all.
    let pendingTransition = null;
    let pendingGlow = null;

    if (!window.__cookingModeBound) {
      window.__cookingModeBound = true;

      // Fullscreen gets exited by plenty of things besides a deliberate
      // "leave cooking mode" action — screen lock, switching apps, a
      // phone's hardware back button — and whether the document even
      // reports itself as hidden when that happens is inconsistent across
      // browsers (Brave doesn't mark it hidden on screen lock the way
      // Chrome/Firefox do, so that can't be used to tell the cases apart
      // reliably). So losing fullscreen no longer ends cooking mode by
      // itself: the wake lock and any running timers stay alive, and the
      // still-visible exit button (or Escape, below) is how you actually
      // leave.
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && document.documentElement.classList.contains('cooking-mode')) {
          exitCookingMode();
        }
      });

      // The Wake Lock is auto-released by the browser whenever the page
      // loses visibility (tab switch, screen lock) — reacquire it once
      // we're back, but only if cooking mode is still meant to be on.
      // Fullscreen may have been force-exited too (see above); best-effort
      // re-request it, though most browsers require a fresh user gesture
      // to grant that, so this silently no-ops there.
      document.addEventListener('visibilitychange', () => {
        if (document.visibilityState === 'visible' && document.documentElement.classList.contains('cooking-mode')) {
          requestWakeLock();
          if (!document.fullscreenElement && document.documentElement.requestFullscreen) {
            document.documentElement.requestFullscreen().catch(() => {});
          }
        }
      });

      // Leaving the recipe page entirely (SPA navigation) shouldn't carry
      // cooking mode into whatever page comes next.
      document.addEventListener('astro:before-swap', () => {
        if (document.documentElement.classList.contains('cooking-mode')) {
          exitCookingMode();
        }
      });
    }

    button.addEventListener('click', (e) => {
      const activating = button.dataset.active !== 'true';

      // Escape/before-swap/visibilitychange reuse enter/exitCookingMode
      // directly (no click coordinates, and a multi-hundred-ms wipe has no
      // business delaying an "I'm leaving" or background re-sync). The
      // button click is the one place we have a pointer position to anchor
      // the reveal on, so only it gets the animated treatment.
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (!document.startViewTransition || reduceMotion) {
        if (activating) enterCookingMode();
        else exitCookingMode();
        return;
      }

      // Tear down a still-pending wipe from a previous click before this
      // one's glow div claims the same view-transition-name (see comment
      // on the pendingTransition/pendingGlow declarations above).
      pendingTransition?.skipTransition();
      pendingGlow?.remove();

      const root = document.documentElement;
      const x = e.clientX;
      const y = e.clientY;
      const endRadius = Math.hypot(Math.max(x, innerWidth - x), Math.max(y, innerHeight - y));

      // Astro tags elements like the recipe image/title with a persistent
      // view-transition-name (via a stylesheet rule keyed on this data
      // attribute) for its own page-navigation transitions — not just
      // while one is in flight. Anything carrying a name gets pulled into
      // ANY view transition on the page, ours included, where it picks up
      // Astro's own unconditional fade animation (held in place the whole
      // time via animation-fill-mode: both, well past its own short
      // duration, for as long as our much longer wipe keeps the overall
      // transition alive). An inline override beats that stylesheet rule's
      // specificity and keeps these elements out of our transition
      // entirely — ordinary pixels in the page's one flat snapshot, as
      // they should be, since this isn't a navigation. Restored once our
      // transition settles so a real navigation afterwards still gets its
      // own shared-element animation.
      const persisted = Array.from(document.querySelectorAll('[data-astro-transition-scope]'));
      persisted.forEach((el) => {
        el.style.viewTransitionName = 'none';
      });

      // A glowing ring that travels with the wipe's edge. It's a real
      // element (not just extra keyframes on the root pseudo) because the
      // ::view-transition tree paints in its own top layer above the rest
      // of the document — anything we didn't also capture into that tree
      // would be hidden behind the wipe, not on top of it. Giving it a
      // view-transition-name of its own pulls it into that same tree as an
      // independently animatable layer.
      //
      // It's created inside the startViewTransition callback (rather than
      // appended beforehand and flipped from opacity 0 to 1 there) so it
      // simply doesn't exist in the "before" snapshot at all — no old
      // counterpart to keep blank, and no reliance on a same-tick style
      // mutation being picked up before the "after" snapshot is captured.
      // That timing is consistent on Chromium desktop, but isn't a
      // cross-engine guarantee, and a raster captured fully transparent
      // can't be un-done later by animating the resulting pseudo's opacity.
      //
      // The live element's own box stays small and fixed — this is what
      // actually gets rasterized (gradient + blur) when the view transition
      // captures it, and that capture is what used to cost 15-20ms+ of
      // extra frame time when this was endRadius * 2 (thousands of pixels
      // across on a typical screen): not just the one-time raster, but every
      // later frame re-compositing that much semi-transparent, blurred
      // pixel area, confirmed by measuring rAF deltas with both the blur
      // kept and removed — removing it barely helped, so the box's sheer
      // on-screen pixel area was the real cost, not the blur filter.
      // Reaching the wipe's actual radius without paying that is below:
      // the captured snapshot is later stretched via `transform: scale()`
      // (see maxScale), which is a compositor-only operation on an
      // already-rasterized layer — cheap regardless of the final on-screen
      // size — confirmed back down at a clean ~16.7ms/frame even scaled up
      // to cover the full wipe radius.
      const ringSize = 260;
      let glow;

      // Only the synchronous class toggle goes through the view transition.
      // Fullscreen is held back until the transition is over (below):
      // toggling it resizes the viewport, and a resize during an active view
      // transition makes the browser silently skip it — exactly the kind of
      // race that would explain the wipe only sometimes showing up.
      root.classList.add('cooking-mode-wipe');
      const transition = document.startViewTransition(() => {
        setActive(activating);
        glow = document.createElement('div');
        // Both cooking-mode backdrops (light: amber/orange/rose pastels, dark:
        // near-black with a rose tint) are themselves warm-toned, so a glow
        // built only from mid-tone oranges/roses blends straight into either
        // one. Contrast comes from a hot core next to a much darker rim —
        // the core pops against the dark backdrop, the rim pops against the
        // light one. The rim is a low-alpha ember brown rather than a flat
        // near-black: a fully opaque dark stop right next to the transparent
        // edge reads as a solid ring outline, not fire, so it fades out
        // gradually instead of snapping dark. The colored stops are bunched
        // up near the outer edge (80%+) rather than spread from 65%, so the
        // band itself reads as a slim ring instead of a wide glowing disc.
        glow.style.cssText = `position:fixed;left:${x}px;top:${y}px;width:${ringSize}px;height:${ringSize}px;border-radius:50%;pointer-events:none;filter:blur(3px);view-transition-name:cooking-mode-flame-glow;transform:translate(-50%,-50%);background:radial-gradient(circle farthest-side, transparent 80%, rgba(255,244,214,0.95) 90%, rgba(254,240,138,1) 93%, rgba(249,115,22,1) 95.5%, rgba(190,18,60,0.9) 97.5%, rgba(76,16,12,0.5) 99%, transparent 100%);`;
        document.body.appendChild(glow);
      });
      pendingGlow = glow;
      pendingTransition = transition;
      transition.ready.then(() => {
        root.animate(
          { clipPath: [`circle(0px at ${x}px ${y}px)`, `circle(${endRadius}px at ${x}px ${y}px)`] },
          { duration: 600, easing: 'ease-in', pseudoElement: '::view-transition-new(root)' }
        );
        // A brief overexposed flash as the new content is revealed, like
        // the wipe is briefly catching light — cheap (just a filter on the
        // already-existing pseudo-element, no extra layer needed).
        root.animate(
          { filter: ['brightness(1.7) saturate(1.6)', 'brightness(1) saturate(1)'] },
          { duration: 320, easing: 'ease-out', pseudoElement: '::view-transition-new(root)' }
        );
        // Animating a ::view-transition-* pseudo always goes through
        // document.documentElement, regardless of which element the name
        // came from — the whole pseudo-element tree is anchored under
        // <html>, not under the originating element. Calling this on
        // `glow` itself targets a pseudo that doesn't exist relative to
        // it, so the animation silently never applies.
        //
        // No translate here, unlike the live element's own inline style:
        // the view-transition group is already captured centered on the
        // click point (it's sized and positioned from the live element's
        // rect, which has the -50%/-50% baked in), so this pseudo's box
        // already sits correctly. A translate(-50%, -50%) on top of that
        // would shift the rendered image by half its own (ringSize-wide)
        // box — hundreds of pixels — leaving the gradient's true center
        // nowhere near the click point at any scale.
        //
        // maxScale stretches the ring's small fixed-size raster so its
        // outer edge reaches endRadius — the same target the wipe's own
        // clip-path animates to, over the same 600ms (the 2/3 offset below,
        // of this animation's 900ms duration). Scale and clip-path radius
        // both follow an 'ease-in' curve to the same target over the same
        // duration, so the ring's edge and the wipe's edge land on the same
        // radius at every instant, not just at the end — confirmed by
        // freeze-framing both at 100ms steps and comparing the computed
        // clip-path radius to the glow's computed transform scale. The
        // extra *1.08 is a small overshoot past that shared target the ring
        // settles back from while it fades out, after the wipe itself has
        // already finished.
        const maxScale = ((endRadius * 2) / ringSize) * 1.08;
        root.animate(
          [
            // A keyframe's `easing` governs the segment FROM it to the next
            // one, not the segment leading into it — so 'ease-in' belongs on
            // keyframe 0 (covers 0→2/3, the growth) and 'ease-out' on
            // keyframe 1 (covers 2/3→1, the tail), not the other way round.
            { transform: 'scale(0)', easing: 'ease-in' },
            { transform: `scale(${maxScale / 1.08})`, offset: 2 / 3, easing: 'ease-out' },
            { transform: `scale(${maxScale})` },
          ],
          { duration: 900, fill: 'forwards', pseudoElement: '::view-transition-new(cooking-mode-flame-glow)' }
        );
        // Opacity used to ride the same 'ease-in' curve as the scale above,
        // which seemed natural — same element, same growth — but 'ease-in'
        // stays slow for most of its run and only accelerates right at the
        // end. That meant the ring was both dim AND still close to the
        // click point (i.e. safely on screen) for most of the animation,
        // and only reached full brightness right as its radius approached
        // endRadius — by definition the distance to the *farthest* viewport
        // corner, so for any click point off-center most of that fully-grown,
        // fully-bright circle's edge has already exited through a nearer
        // edge. The net effect was a glow that was only ever bright while
        // mostly off-screen. Giving opacity its own timeline — ramping to
        // full brightness almost immediately and holding it there — means
        // the ring is already lit up while it's still small and near the
        // click point, fading out only at the very end regardless of how
        // far it's grown by then.
        //
        // 'easing' as a top-level option (rather than per-keyframe) warps
        // progress across the WHOLE duration before keyframes are looked
        // up, not within each segment — so putting 'ease-out' there (as
        // this used to) raced the eased progress ahead of real time and
        // ate into the 0.18–0.7 plateau, fading the ring out well before
        // 630ms instead of holding it at full brightness until then.
        // Putting 'ease-out' on the offset-0.7 keyframe instead scopes it
        // to just the tail segment (0.7→1) it's meant to ease, leaving the
        // ramp-up and plateau untouched.
        root.animate(
          [
            { opacity: 0 },
            { opacity: 1, offset: 0.18 },
            { opacity: 1, offset: 0.7, easing: 'ease-out' },
            { opacity: 0 },
          ],
          { duration: 900, fill: 'forwards', pseudoElement: '::view-transition-new(cooking-mode-flame-glow)' }
        );
      });
      // A duplicate-name conflict (see above) makes the browser skip the
      // transition outright, rejecting `ready` with nothing to catch it —
      // not an error worth surfacing, since the cooking-mode toggle itself
      // (inside the startViewTransition callback above) already went
      // through regardless; only the wipe/glow animation was skipped.
      transition.ready.catch(() => {});
      transition.finished.finally(() => {
        if (pendingGlow === glow) pendingGlow = null;
        glow.remove();
        persisted.forEach((el) => {
          el.style.viewTransitionName = '';
        });
        // A later click may have already skipped this transition and
        // started its own — don't let this stale finally undo state (the
        // wipe class, wake lock, fullscreen) that the newer one now owns.
        if (pendingTransition !== transition) return;
        pendingTransition = null;
        root.classList.remove('cooking-mode-wipe');
        if (activating) {
          requestWakeLock();
          if (root.requestFullscreen) root.requestFullscreen().catch(() => {});
        } else {
          releaseWakeLock();
          if (document.fullscreenElement) document.exitFullscreen().catch(() => {});
        }
      });
    });
  }

  document.addEventListener('astro:page-load', bindCookingModeButton);
</script>
