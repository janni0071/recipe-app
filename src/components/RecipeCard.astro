---
import { Image } from 'astro:assets';

export interface Props {
  title: string;
  tags: string[];
  prepTime: string;
  cookTime: string;
  slug: string;
  image?: string;
}
const { title, tags, prepTime, cookTime, slug, image } = Astro.props;
---
<a href={`/recipes/${slug}`} class="block group">
  <div class="bg-white rounded-xl shadow-md overflow-hidden transition hover:shadow-lg dark:bg-gray-800 dark:shadow-gray-900">
    {image && (
      <div class="h-48 bg-gray-200 overflow-hidden dark:bg-gray-700">
        <Image
          src={image}
          alt={title}
          class="w-full h-full object-cover group-hover:scale-105 transition"
          width={400}
          height={300}
          format="webp"
          loading="lazy"
          decoding="async"
        />
      </div>
    )}
    <div class="p-4">
      <h3 class="text-xl font-semibold mb-2 dark:text-white">{title}</h3>
      <div class="flex flex-wrap gap-2 mb-3">
        {tags.map(tag => (
          <span class="text-xs bg-rose-100 text-rose-700 px-2 py-1 rounded-full dark:bg-rose-900 dark:text-rose-200">
            #{tag}
          </span>
        ))}
      </div>
      <div class="flex justify-between text-sm text-gray-500 dark:text-gray-400">
        <span>⏱️ Prep: {prepTime}</span>
        <span>🍳 Cook: {cookTime}</span>
      </div>
    </div>
  </div>
</a>
