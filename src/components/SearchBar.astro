---
export interface SearchItem {
  title: string;
  tags: string[];
  ingredients?: string[];
  href: string;
}

interface Props {
  placeholder?: string;
  noResultsLabel?: string;
  // Template for the "why did this match?" hint, with a {name} placeholder,
  // e.g. "contains {name}". Shown only on ingredient-only matches.
  matchedIngredientLabel?: string;
  items: SearchItem[];
}

const {
  placeholder = 'Search for recipes...',
  noResultsLabel = 'No matches found',
  matchedIngredientLabel = 'contains {name}',
  items,
} = Astro.props;
---

<div
  id="recipe-search"
  class="relative"
  data-items={JSON.stringify(items)}
  data-no-results-label={noResultsLabel}
  data-matched-label={matchedIngredientLabel}
>
  <input
    type="search"
    id="recipe-search-input"
    placeholder={placeholder}
    autocomplete="off"
    class="h-12 w-full rounded-lg border border-gray-300 bg-white px-4 text-sm focus:outline-none focus:ring-2 focus:ring-pink-400 dark:border-gray-700 dark:bg-gray-800 dark:text-gray-100 dark:placeholder-gray-500 sm:h-11"
  />
  <ul
    id="recipe-search-results"
    class="absolute z-20 mt-2 hidden max-h-80 w-full divide-y divide-gray-100 overflow-y-auto rounded-xl border border-gray-200 bg-white shadow-lg dark:divide-gray-700 dark:border-gray-700 dark:bg-gray-800"
  ></ul>
</div>

<script is:inline>
  // Astro's ClientRouter skips re-running an inline script whose text content
  // already ran earlier this session — and since define:vars bakes literal
  // data into that text, revisiting the same locale produces byte-identical
  // script content to its first visit, so it'd get silently skipped and the
  // search data would go stale. So: no define:vars, no data baked into the
  // script. The items/labels live as attributes on the container, which is
  // plain HTML and always gets refreshed by the swap regardless of script
  // dedup. This script's only job is to (re)bind listeners to whatever the
  // current DOM looks like, reading data fresh from it each time.
  function bindSearchInput() {
    const container = document.getElementById('recipe-search');
    const input = document.getElementById('recipe-search-input');
    const results = document.getElementById('recipe-search-results');
    if (!container || !input || !results || input.dataset.searchBound) return;
    input.dataset.searchBound = 'true';

    function render(query) {
      const q = query.trim().toLowerCase();
      results.innerHTML = '';

      // Grid filtering (which also needs to combine with the "favorites
      // only" toggle) lives in a shared function in BaseLayout — it reads
      // the input's value straight from the DOM, so just asking it to
      // recompute is enough; it doesn't need anything passed in.
      if (window.applyRecipeGridFilters) window.applyRecipeGridFilters();

      // On desktop, the recipe grid is visible while typing so the grid IS
      // the results UI — hide the dropdown to avoid duplication. On mobile
      // the on-screen keyboard covers the grid, so the dropdown is the only
      // visible results panel; keep it available below the sm breakpoint.
      results.classList.toggle('sm:hidden', !!document.getElementById('recipe-grid'));

      if (!q) {
        results.classList.add('hidden');
        return;
      }

      let items = [];
      try {
        items = JSON.parse(container.dataset.items || '[]');
      } catch {
        items = [];
      }
      const noResultsLabel = container.dataset.noResultsLabel || '';
      const matchedLabel = container.dataset.matchedLabel || '';

      // Rank each match by *why* it matched: a title hit (0) outranks a tag hit
      // (1), which outranks an ingredient-only hit (2). We stop at the first
      // reason so an ingredient-only match is the only kind that carries a hint.
      // Array.sort is stable, so within a rank the original (newest-first) order
      // is kept.
      const scored = [];
      for (const item of items) {
        if (item.title.toLowerCase().includes(q)) {
          scored.push({ item, rank: 0 });
        } else if ((item.tags || []).some((tag) => tag.toLowerCase().includes(q))) {
          scored.push({ item, rank: 1 });
        } else {
          const ingredient = (item.ingredients || []).find((n) => n.toLowerCase().includes(q));
          if (ingredient) scored.push({ item, rank: 2, ingredient });
        }
      }
      scored.sort((a, b) => a.rank - b.rank);

      if (scored.length === 0) {
        // On the homepage the grid empty state handles no-results, so close
        // the dropdown and let that show instead. On other pages (no grid)
        // the dropdown is the only results UI, so show the empty state there.
        if (document.getElementById('recipe-grid')) {
          results.classList.add('hidden');
          return;
        }
        const li = document.createElement('li');
        li.className = 'py-8 text-center';
        const icon = document.createElement('div');
        icon.setAttribute('aria-hidden', 'true');
        icon.className = 'mb-2';
        icon.innerHTML = '<svg class="mx-auto w-8 h-8 text-gray-300 dark:text-gray-500" aria-hidden="true"><use href="#icon-search"></use></svg>';
        const msg = document.createElement('p');
        msg.className = 'text-sm text-gray-500 dark:text-gray-400';
        msg.textContent = noResultsLabel;
        li.append(icon, msg);
        results.append(li);
      } else {
        for (const { item, ingredient } of scored) {
          const li = document.createElement('li');
          const a = document.createElement('a');
          a.href = item.href;
          a.className =
            'block px-4 py-3 hover:bg-pink-50 active:bg-pink-100 dark:hover:bg-gray-700 dark:active:bg-gray-600';

          const titleEl = document.createElement('div');
          titleEl.className = 'truncate text-base text-gray-900 dark:text-gray-100';
          titleEl.textContent = item.title;
          a.append(titleEl);

          // Only ingredient-only matches get a hint — for a title/tag match the
          // reason is already obvious from the title the user sees.
          if (ingredient) {
            const hint = document.createElement('div');
            hint.className = 'truncate text-xs text-gray-400 dark:text-gray-500 mt-0.5';
            hint.textContent = matchedLabel.replace('{name}', ingredient);
            a.append(hint);
          }

          li.append(a);
          results.append(li);
        }
      }
      results.classList.remove('hidden');
    }

    input.addEventListener('input', (e) => render(e.target.value));
    input.addEventListener('focus', () => {
      if (input.value.trim()) render(input.value);
    });
    input.addEventListener('blur', () => {
      // Delay hiding so a click on a result registers before it disappears.
      // The grid filter itself is left as-is — clearing it is what resets that.
      setTimeout(() => results.classList.add('hidden'), 150);
    });
    input.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        input.value = '';
        render('');
        input.blur();
      }
    });
  }

  bindSearchInput();
  if (!window.__recipeSearchSwapListenerAdded) {
    window.__recipeSearchSwapListenerAdded = true;
    document.addEventListener('astro:after-swap', bindSearchInput);
  }
</script>
