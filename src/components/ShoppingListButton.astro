---
export interface Props {
  slug: string;
  label: string;
  class?: string;
}

const {
  slug,
  label,
  class: className = 'bg-pink-100 hover:bg-pink-200 dark:bg-pink-900 dark:hover:bg-pink-800 text-pink-600 dark:text-pink-300',
} = Astro.props;
---

<button
  type="button"
  data-shopping-slug={slug}
  data-in-list="false"
  aria-pressed="false"
  aria-label={label}
  class={`group relative flex-shrink-0 p-3 rounded-full transition ${className}`}
>
  <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
    <circle cx="9" cy="21" r="1.5"></circle>
    <circle cx="20" cy="21" r="1.5"></circle>
    <path stroke-linecap="round" stroke-linejoin="round" d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
  </svg>
  <span class="hidden group-data-[in-list=true]:flex absolute -top-1 -right-1 w-4 h-4 items-center justify-center rounded-full bg-green-500 ring-2 ring-pink-100 dark:ring-pink-900">
    <svg class="w-2.5 h-2.5 text-white" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
      <path d="M20 6L9 17l-5-5"></path>
    </svg>
  </span>
</button>
