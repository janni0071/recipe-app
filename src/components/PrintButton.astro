---
export interface Props {
  label: string;
}

const { label } = Astro.props;
---

<button
  type="button"
  id="print-button"
  aria-label={label}
  class="flex-shrink-0 p-3 rounded-full bg-pink-100 hover:bg-pink-200 dark:bg-pink-900 dark:hover:bg-pink-800 text-pink-600 dark:text-pink-300 transition"
>
  <svg class="w-5 h-5" aria-hidden="true"><use href="#icon-printer"/></svg>
</button>

<script is:inline>
  // Generic, identical content on every recipe page — same dedup-safe
  // astro:page-load pattern as ShareButton/theme-toggle. No per-page data
  // needed at all here, so there's nothing that can go stale.
  function bindPrintButton() {
    const button = document.getElementById('print-button');
    if (!button) return;
    button.addEventListener('click', () => window.print());
  }

  document.addEventListener('astro:page-load', bindPrintButton);
</script>
