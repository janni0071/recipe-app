---
import { formatAmount, unitAndName, type IngredientGroup } from '../utils/ingredients';
export type { IngredientItem, IngredientGroup } from '../utils/ingredients';

export interface Props {
  heading: string;
  groups: IngredientGroup[];
  servings: number;
  servingsLabel: string;
}

const { heading, groups, servings, servingsLabel } = Astro.props;
---
<div class="flex flex-wrap items-center justify-between gap-3">
  <h2 class="!mt-0 !mb-0">{heading}</h2>
  <div
    id="servings-stepper"
    class="flex items-center gap-2 text-sm font-medium text-gray-600 dark:text-gray-300"
    data-base-servings={servings}
  >
    <span class="print:hidden capitalize">{servingsLabel}</span>
    <div class="print:hidden flex items-center rounded-full bg-gray-100 cooking-mode:bg-white/55 dark:bg-gray-700 dark:cooking-mode:bg-white/10">
      <button
        type="button"
        id="servings-decrement"
        aria-label="Decrease servings"
        class="w-11 h-11 flex items-center justify-center text-lg rounded-full hover:bg-gray-200 active:bg-gray-300 cooking-mode:hover:bg-white/75 cooking-mode:active:bg-white/90 dark:hover:bg-gray-600 dark:active:bg-gray-500 dark:cooking-mode:hover:bg-white/15 dark:cooking-mode:active:bg-white/20 transition disabled:opacity-40"
      >
        −
      </button>
      <span class="servings-value min-w-[2rem] text-center text-base font-semibold text-gray-900 dark:text-gray-100">{servings}</span>
      <button
        type="button"
        id="servings-increment"
        aria-label="Increase servings"
        class="w-11 h-11 flex items-center justify-center text-lg rounded-full hover:bg-gray-200 active:bg-gray-300 cooking-mode:hover:bg-white/75 cooking-mode:active:bg-white/90 dark:hover:bg-gray-600 dark:active:bg-gray-500 dark:cooking-mode:hover:bg-white/15 dark:cooking-mode:active:bg-white/20 transition"
      >
        +
      </button>
    </div>
    <span class="hidden print:inline capitalize">
      <span class="servings-value">{servings}</span> {servingsLabel}
    </span>
  </div>
</div>

{groups.map((group) => (
  <>
    {group.heading && <h3>{group.heading}</h3>}
    <ul>
      {group.items.map((item) => (
        <li>
          {item.amount != null && (
            <>
              <span class="ing-amount" data-amount={item.amount} data-amount-max={item.amountMax}>
                {formatAmount(item.amount, item.amountMax)}
              </span>{' '}
            </>
          )}
          {unitAndName(item.unit, item.name)}
        </li>
      ))}
    </ul>
  </>
))}

<script is:inline>
  function initServingsStepper() {
    const stepper = document.getElementById('servings-stepper');
    if (!stepper) return;

    const baseServings = parseFloat(stepper.dataset.baseServings || '1');
    const valueEls = stepper.querySelectorAll('.servings-value');
    const decrementBtn = document.getElementById('servings-decrement');
    const incrementBtn = document.getElementById('servings-increment');
    const amountEls = document.querySelectorAll('.ing-amount');

    function scale(n, multiplier) {
      return Math.round(n * multiplier * 100) / 100;
    }

    function render(servings) {
      valueEls.forEach((el) => { el.textContent = servings; });
      const multiplier = servings / baseServings;
      amountEls.forEach((el) => {
        const amount = parseFloat(el.dataset.amount);
        const amountMax = el.dataset.amountMax ? parseFloat(el.dataset.amountMax) : null;
        el.textContent = amountMax != null
          ? `${scale(amount, multiplier)}-${scale(amountMax, multiplier)}`
          : `${scale(amount, multiplier)}`;
      });
      decrementBtn.disabled = servings <= 1;
    }

    let servings = baseServings;
    decrementBtn.addEventListener('click', () => {
      if (servings > 1) render(--servings);
    });
    incrementBtn.addEventListener('click', () => {
      render(++servings);
    });
    render(servings);
  }

  document.addEventListener('astro:page-load', initServingsStepper);
</script>
