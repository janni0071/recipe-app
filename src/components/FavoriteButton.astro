---
export interface Props {
  slug: string;
  label: string;
  class?: string;
}

const {
  slug,
  label,
  class: className = 'bg-pink-100 hover:bg-pink-200 dark:bg-pink-900 dark:hover:bg-pink-800 text-pink-600 dark:text-pink-300',
} = Astro.props;
---

<button
  type="button"
  data-favorite-slug={slug}
  data-favorited="false"
  aria-pressed="false"
  aria-label={label}
  class={`group flex-shrink-0 p-3 rounded-full transition ${className}`}
>
  <svg class="w-5 h-5 group-data-[favorited=true]:hidden" aria-hidden="true"><use href="#icon-heart-outline"/></svg>
  <svg class="hidden w-5 h-5 group-data-[favorited=true]:block" aria-hidden="true"><use href="#icon-heart-filled"/></svg>
</button>
