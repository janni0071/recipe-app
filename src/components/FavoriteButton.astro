---
export interface Props {
  slug: string;
  label: string;
  class?: string;
}

const {
  slug,
  label,
  class: className = 'bg-pink-100 hover:bg-pink-200 dark:bg-pink-900 dark:hover:bg-pink-800 text-pink-600 dark:text-pink-300',
} = Astro.props;
---

<button
  type="button"
  data-favorite-slug={slug}
  data-favorited="false"
  aria-pressed="false"
  aria-label={label}
  class={`group flex-shrink-0 p-3 rounded-full transition ${className}`}
>
  <svg class="w-5 h-5 group-data-[favorited=true]:hidden" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
    <path
      stroke-linecap="round"
      stroke-linejoin="round"
      d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"
    ></path>
  </svg>
  <svg class="hidden w-5 h-5 group-data-[favorited=true]:block" fill="currentColor" viewBox="0 0 24 24">
    <path
      d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"
    ></path>
  </svg>
</button>
