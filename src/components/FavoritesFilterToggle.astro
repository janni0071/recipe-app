---
export interface Props {
  label: string;
}

const { label } = Astro.props;
---

<button
  type="button"
  id="favorites-filter-toggle"
  data-active="false"
  aria-pressed="false"
  class="group flex h-12 items-center gap-1.5 rounded-lg border border-gray-300 px-4 text-sm text-gray-600 transition hover:bg-gray-100 data-[active=true]:border-pink-400 data-[active=true]:bg-pink-100 data-[active=true]:text-pink-700 dark:border-gray-700 dark:text-gray-300 dark:hover:bg-gray-700 dark:data-[active=true]:bg-pink-900 dark:data-[active=true]:text-pink-200 sm:h-11"
>
  <svg class="w-4 h-4 group-data-[active=true]:hidden" aria-hidden="true"><use href="#icon-heart-outline"/></svg>
  <svg class="hidden w-4 h-4 group-data-[active=true]:block" aria-hidden="true"><use href="#icon-heart-filled"/></svg>
  {label}
</button>

<script is:inline>
  function bindFavoritesFilterToggle() {
    const button = document.getElementById('favorites-filter-toggle');
    if (!button || button.dataset.toggleBound) return;
    button.dataset.toggleBound = 'true';

    button.addEventListener('click', () => {
      const active = button.dataset.active === 'true';
      button.dataset.active = String(!active);
      button.setAttribute('aria-pressed', String(!active));
      if (window.applyRecipeGridFilters) window.applyRecipeGridFilters();
    });
  }

  document.addEventListener('astro:page-load', bindFavoritesFilterToggle);
</script>
