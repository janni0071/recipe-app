---
import type { Locale } from '../utils/i18n';
import { useTranslations, getLocalePath, getTagsPath } from '../utils/i18n';
import LanguageSwitcher from '../components/LanguageSwitcher.astro';
import { ClientRouter } from 'astro:transitions';

export interface Props {
  title: string;
  description?: string;
  // Accepts both raw ImageMetadata and getImage()'s GetImageResult — callers
  // should pass an already-optimized variant (e.g. via getImage()), not a
  // raw content-collection image reference, or og:image ends up pointing at
  // the full-resolution original instead of a web-sized crop.
  image?: { src: string };
  localeUrls?: Partial<Record<Locale, string>>;
}
const { title, description, image, localeUrls } = Astro.props;
const locale = (Astro.currentLocale ?? 'en') as Locale;
const t = useTranslations(locale);
const homePath = getLocalePath(locale);
const tagsPath = getTagsPath(locale);
import '../styles/global.css';

const pageTitle = `${title} | Recipe Box`;
const pageDescription = description || 'Our family recipes';
const pageUrl = new URL(Astro.url.pathname, Astro.site);
const ogImageUrl = image ? new URL(image.src, Astro.site) : undefined;
---
<!DOCTYPE html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={pageUrl} />
    {ogImageUrl && <meta property="og:image" content={ogImageUrl} />}

    <meta name="twitter:card" content={ogImageUrl ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    {ogImageUrl && <meta name="twitter:image" content={ogImageUrl} />}

    <ClientRouter />
    <script is:inline>
      function applyTheme(doc) {
        const theme = localStorage.getItem('theme-preference') ?? 'dark';
        doc.documentElement.classList.toggle('dark', theme === 'dark');
      }
      applyTheme(document);
      // Apply theme to the incoming document before it swaps in, so back/forward
      // navigation never paints a frame in the wrong theme first.
      document.addEventListener('astro:before-swap', (event) => applyTheme(event.newDocument));
    </script>
  </head>
  <body class="bg-gray-50 text-gray-900 dark:bg-gray-900 dark:text-gray-100 transition-colors">
    <header class="print:hidden border-b bg-white p-4 shadow-sm dark:bg-gray-800 dark:border-gray-700">
      <nav class="mx-auto max-w-6xl flex justify-between items-center gap-2 flex-wrap">
        <a href={homePath} class="text-xl sm:text-2xl font-bold text-pink-500 dark:text-pink-400">🍽️ Recipe Box</a>
        <div class="flex items-center gap-3 flex-wrap justify-end">
          <a href={homePath} class="hidden sm:inline hover:underline">{t('nav.home')}</a>
          <a href={tagsPath} class="hidden sm:inline hover:underline">{t('nav.tags')}</a>
          <a href={tagsPath} class="sm:hidden px-3 py-2 rounded-lg text-base font-medium bg-gray-200 hover:bg-gray-300 dark:bg-gray-700 dark:hover:bg-gray-600 transition">{t('nav.tags')}</a>
          <LanguageSwitcher currentLocale={locale} localeUrls={localeUrls} />
          <button id="theme-toggle" class="p-2 rounded-full bg-gray-200 dark:bg-gray-700 hover:bg-gray-300 dark:hover:bg-gray-600 transition">
            <svg id="theme-toggle-sun" class="w-5 h-5 hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"></path>
            </svg>
            <svg id="theme-toggle-moon" class="w-5 h-5 block dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path>
            </svg>
          </button>
        </div>
      </nav>
    </header>
    <main class="mx-auto max-w-6xl p-4">
      <slot />
    </main>
    <footer class="print:hidden mt-12 border-t py-6 text-center text-sm text-gray-500 dark:border-gray-800 dark:text-gray-400">
        © {new Date().getFullYear()} Jannis
        <span class="relative group inline-block cursor-default">
          <span class="text-pink-400 group-hover:text-pink-500 transition">♡</span>
          <span class="pointer-events-none absolute -top-8 left-1/2 -translate-x-1/2 whitespace-nowrap rounded-lg bg-pink-100 text-pink-700 dark:bg-pink-950 dark:text-pink-300 px-2 py-1 text-xs opacity-0 group-hover:opacity-100 transition-opacity duration-200 shadow">
            Made with love 🍳
          </span>
        </span>
        Daisy
    </footer>
    <script is:inline>
      function setupThemeToggle() {
        const button = document.getElementById('theme-toggle');
        if (button) {
          button.addEventListener('click', () => {
            const isDark = document.documentElement.classList.contains('dark');
            const next = isDark ? 'light' : 'dark';
            document.documentElement.classList.toggle('dark', next === 'dark');
            localStorage.setItem('theme-preference', next);
          });
        }
      }
      // astro:page-load fires on initial load and after every navigation
      document.addEventListener('astro:page-load', setupThemeToggle);
    </script>
    <script is:inline>
      // RecipeCard marks its linked recipe's hero image via data-hero-src.
      // Once a card has been visible for a moment (matching the 300ms dwell
      // time Astro's own viewport prefetch strategy uses), fetch that hero
      // image in the background at low priority, so it's already cached by
      // the time the user actually clicks through — fixing the "image
      // briefly disappears" flash on a first visit. One shared observer for
      // the whole session; this script's content never changes between
      // pages, so the ClientRouter will only ever run it once, and that's
      // fine — the observer just needs to (re)scan for fresh cards each nav.
      //
      // Cards already on screen at page load skip the dwell delay entirely
      // and prefetch right away: there's no "user is scrolling past quickly"
      // risk to guard against for content that was visible before any
      // scrolling happened. This is what was making the desktop grid (which
      // shows every card without scrolling) feel slower than mobile to open
      // a recipe on the first visit. It's bounded by how many cards fit in
      // one screen, not by the total recipe count, so it stays cheap as the
      // catalog grows — only cards revealed by scrolling further still wait
      // out the 300ms dwell.
      function initHeroPreload() {
        if (!window.__heroPreloadObserver) {
          window.__heroPreloadedHrefs = new Set();
          const pendingTimers = new WeakMap();
          const seenElements = new WeakSet();

          function prefetch(el) {
            const href = el.dataset.heroSrc;
            window.__heroPreloadObserver.unobserve(el);
            if (!href || window.__heroPreloadedHrefs.has(href)) return;
            window.__heroPreloadedHrefs.add(href);
            // A real fetch() warms the HTTP cache directly, instead of just
            // hinting — browsers are free to deprioritize or skip a <link
            // rel=prefetch> outright (e.g. to save data/battery on mobile),
            // which was letting the hero image sometimes still be uncached
            // by the time the recipe was actually opened.
            fetch(href, { priority: 'low' }).catch(() => {});
          }

          window.__heroPreloadObserver = new IntersectionObserver((entries) => {
            for (const entry of entries) {
              const el = entry.target;
              const isFirstReport = !seenElements.has(el);
              seenElements.add(el);

              if (entry.isIntersecting) {
                if (isFirstReport) {
                  prefetch(el);
                } else {
                  const timer = setTimeout(() => prefetch(el), 300);
                  pendingTimers.set(el, timer);
                }
              } else {
                const timer = pendingTimers.get(el);
                if (timer) clearTimeout(timer);
              }
            }
          });
        }

        document.querySelectorAll('[data-hero-src]').forEach((el) => {
          window.__heroPreloadObserver.observe(el);
        });
      }

      document.addEventListener('astro:page-load', initHeroPreload);
    </script>
    <script is:inline>
      // Favorites live in localStorage, keyed by the recipe's locale-agnostic
      // slug — favoriting a recipe in one language keeps it favorited after
      // switching languages, since it's the same recipe either way.
      function getFavoriteSlugs() {
        try {
          return new Set(JSON.parse(localStorage.getItem('favorite-recipes') || '[]'));
        } catch {
          return new Set();
        }
      }

      function setFavoriteSlugs(slugs) {
        localStorage.setItem('favorite-recipes', JSON.stringify([...slugs]));
      }

      function syncFavoriteButtons() {
        const favorites = getFavoriteSlugs();
        document.querySelectorAll('[data-favorite-slug]').forEach((button) => {
          const active = favorites.has(button.dataset.favoriteSlug);
          button.dataset.favorited = String(active);
          button.setAttribute('aria-pressed', String(active));
        });
      }

      // Single shared filter, callable from both the search box and the
      // "favorites only" toggle, so the two compose with simple AND logic
      // instead of each independently fighting over the same hidden class.
      // Reads everything fresh from the live DOM/localStorage on every call
      // rather than being passed state, so either caller can trigger a
      // recompute without needing to know about the other's internals.
      window.applyRecipeGridFilters = function () {
        const grid = document.getElementById('recipe-grid');
        if (!grid) return;

        const searchInput = document.getElementById('recipe-search-input');
        const query = (searchInput?.value || '').trim().toLowerCase();
        const favoritesToggle = document.getElementById('favorites-filter-toggle');
        const favoritesOnly = favoritesToggle?.dataset.active === 'true';
        const favorites = getFavoriteSlugs();

        let visibleCount = 0;
        for (const card of grid.children) {
          const title = (card.dataset.recipeTitle || '').toLowerCase();
          const tags = (card.dataset.recipeTags || '').split(',');
          const slug = card.dataset.recipeSlug;
          const matchesQuery = !query || title.includes(query) || tags.some((tag) => tag.includes(query));
          const matchesFavorites = !favoritesOnly || (!!slug && favorites.has(slug));
          const visible = matchesQuery && matchesFavorites;
          card.classList.toggle('hidden', !visible);
          if (visible) visibleCount++;
        }

        const emptyMessage = document.getElementById('recipe-grid-empty');
        const filtering = query !== '' || favoritesOnly;
        if (emptyMessage) emptyMessage.classList.toggle('hidden', !filtering || visibleCount > 0);
      };

      function initFavorites() {
        if (!window.__favoritesClickBound) {
          window.__favoritesClickBound = true;
          // Astro's <ClientRouter/> registers its own click listener in
          // <head> (bubble phase) that calls navigate() directly as soon as
          // it sees an unprevented click on an anchor — it runs, and starts
          // navigating, before a later bubble-phase listener like this one
          // would even get a turn. Using the capture phase here makes this
          // listener run first regardless of registration order, so
          // stopPropagation() actually has a chance to take effect.
          document.addEventListener(
            'click',
            (e) => {
              const button = e.target.closest('[data-favorite-slug]');
              if (!button) return;
              e.preventDefault();
              e.stopPropagation();
              const slug = button.dataset.favoriteSlug;
              const favorites = getFavoriteSlugs();
              if (favorites.has(slug)) favorites.delete(slug);
              else favorites.add(slug);
              setFavoriteSlugs(favorites);
              syncFavoriteButtons();
              window.applyRecipeGridFilters();
            },
            true
          );
        }
        syncFavoriteButtons();
      }

      document.addEventListener('astro:page-load', initFavorites);
    </script>
    <script is:inline>
      // RecipeCard renders every tag server-side; if they'd wrap to a second
      // row, collapse the overflow into a single "+N" pill instead, so
      // cards in the same grid row stay visually aligned. Re-checks on
      // resize too, since the same card can wrap differently as the
      // viewport (and the grid's column count) changes.
      function collapseTagRows() {
        document.querySelectorAll('[data-tag-row]').forEach((row) => {
          const tags = Array.from(row.querySelectorAll('[data-tag]'));
          const moreBadge = row.querySelector('[data-tag-more]');
          if (tags.length === 0) return;

          // Reset to the "everything visible" state first — a single write
          // batch, before any reads happen.
          tags.forEach((tag) => tag.classList.remove('hidden'));
          if (moreBadge) moreBadge.classList.add('hidden');

          // Read every tag's offsetTop up front, in one batch, instead of
          // interleaving reads with hide-writes in a loop — the latter
          // forces a fresh synchronous layout recalculation on every
          // iteration ("layout thrashing"), since each write invalidates
          // the layout the next read would otherwise reuse.
          const tops = tags.map((tag) => tag.offsetTop);
          const firstRowTop = tops[0];
          const overflowing = tags.filter((_, i) => tops[i] > firstRowTop);

          if (overflowing.length === 0 || !moreBadge) return;

          overflowing.forEach((tag) => tag.classList.add('hidden'));
          let hiddenCount = overflowing.length;
          moreBadge.textContent = `+${hiddenCount}`;
          moreBadge.classList.remove('hidden');

          // The badge itself takes up row space — if adding it pushed it
          // onto row 2, hide one more real tag and retry. This part stays
          // iterative (we only know whether the badge fits once it's
          // actually shown), but it's capped and rarely runs more than once.
          for (let guard = 0; guard < 10 && moreBadge.offsetTop > firstRowTop; guard++) {
            const visible = tags.filter((tag) => !tag.classList.contains('hidden'));
            const last = visible[visible.length - 1];
            if (!last) break;
            last.classList.add('hidden');
            hiddenCount++;
            moreBadge.textContent = `+${hiddenCount}`;
          }
        });
      }

      document.addEventListener('astro:page-load', collapseTagRows);

      if (!window.__tagRowResizeBound) {
        window.__tagRowResizeBound = true;
        let resizeTimer;
        window.addEventListener('resize', () => {
          clearTimeout(resizeTimer);
          resizeTimer = setTimeout(collapseTagRows, 150);
        });
      }
    </script>
    </body>
</html>
