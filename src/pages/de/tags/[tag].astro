---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import RecipeCard from '../../../components/RecipeCard.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { useTranslations, getTagsPath } from '../../../utils/i18n';
import { getTagTranslations } from '../../../utils/tags';
import { EAGER_CARD_COUNT } from '../../../utils/imageLoading';

export async function getStaticPaths(): Promise<{ params: { tag: string } }[]> {
  const recipes = await getCollection('recipes');
  const allTags = new Set<string>();
  recipes
    .filter((recipe: CollectionEntry<'recipes'>) => recipe.id.startsWith('de/'))
    .forEach((recipe: CollectionEntry<'recipes'>) => {
      recipe.data.tags.forEach((tag: string) => allTags.add(tag));
    });
  return Array.from(allTags).map((tag: string) => ({ params: { tag } }));
}

const t = useTranslations('de');
const { tag } = Astro.params as { tag: string };

const allRecipes = await getCollection('recipes');
const filteredRecipes = allRecipes.filter((recipe: CollectionEntry<'recipes'>) =>
  recipe.id.startsWith('de/') && recipe.data.tags.includes(tag!)
);

const recipesWithSlug = filteredRecipes.map((recipe: CollectionEntry<'recipes'>) => ({
  ...recipe,
  slug: recipe.id.replace(/^de\//, '').replace(/\.md$/, '')
}));

const tagTranslations = await getTagTranslations();
const localeUrls = {
  en: tagTranslations.de.en[tag] ? `/tags/${tagTranslations.de.en[tag]}` : getTagsPath('en'),
  de: `/de/tags/${tag}`,
  fr: tagTranslations.de.fr[tag] ? `/fr/tags/${tagTranslations.de.fr[tag]}` : getTagsPath('fr'),
};
---
<BaseLayout title={`${t('page.tag.heading')} #${tag}`} localeUrls={localeUrls}>
  <a href={getTagsPath('de')} class="inline-block mb-4 text-sm text-gray-600 hover:text-pink-600 hover:underline dark:text-gray-400 dark:hover:text-pink-400">{t('page.tag.allTags')}</a>
  <h1 class="text-3xl font-bold mb-2">{t('page.tag.heading')} <span class="text-pink-600">#{tag}</span></h1>
  <p class="mb-6 text-gray-600 dark:text-gray-400">{filteredRecipes.length} {t('page.tag.count')}</p>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    {recipesWithSlug.map((recipe, i) => (
      <RecipeCard
        title={recipe.data.title}
        tags={recipe.data.tags}
        prepTime={recipe.data.prepTime}
        cookTime={recipe.data.cookTime}
        prepLabel={t('page.recipe.prep')}
        cookLabel={t('page.recipe.cook')}
        favoriteLabel={t('page.recipe.favorite')}
        slug={recipe.slug}
        image={recipe.data.image}
        baseRecipePath="/de/recipes/"
        loading={i < EAGER_CARD_COUNT ? 'eager' : 'lazy'}
      />
    ))}
  </div>
</BaseLayout>
