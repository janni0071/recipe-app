---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RecipeCard from '../../components/RecipeCard.astro';
import Search from '../../components/SearchBar.astro';
import FavoritesFilterToggle from '../../components/FavoritesFilterToggle.astro';
import SortControl from '../../components/SortControl.astro';
import TimeFilter from '../../components/TimeFilter.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { useTranslations, getIndexHeadingParts } from '../../utils/i18n';
import { ingredientNames } from '../../utils/ingredients';
import { EAGER_CARD_COUNT } from '../../utils/imageLoading';

const t = useTranslations('de');
const heading = getIndexHeadingParts('de');
const allRecipes = await getCollection('recipes');
const sortedRecipes = allRecipes
  .filter((r: CollectionEntry<'recipes'>) => r.id.startsWith('de/'))
  .sort((a: CollectionEntry<'recipes'>, b: CollectionEntry<'recipes'>) =>
  b.data.date.getTime() - a.data.date.getTime()
);

const recipesWithSlug = sortedRecipes.map((recipe: CollectionEntry<'recipes'>) => ({
  ...recipe,
  slug: recipe.id.replace(/^de\//, '').replace(/\.md$/, '')
}));

const searchItems = recipesWithSlug.map((recipe) => ({
  title: recipe.data.title,
  tags: recipe.data.tags,
  ingredients: ingredientNames(recipe.data.ingredients),
  href: `/de/recipes/${recipe.slug}`,
}));
---
<BaseLayout title={t('page.index.title')} showHeaderSearch={false}>
  <h1 class="text-3xl font-bold mb-6">{heading.before}<span class="text-pink-500 dark:text-pink-400">{heading.names}</span>{heading.after}</h1>

  <div class="mb-4 flex flex-wrap items-center gap-3">
    <div class="w-full sm:w-auto sm:flex-1 sm:min-w-[12rem]">
      <Search placeholder={t('search.placeholder')} noResultsLabel={t('search.noResults')} matchedIngredientLabel={t('search.matchedIngredient')} items={searchItems} />
    </div>
    <div class="flex items-center gap-3">
      <FavoritesFilterToggle label={t('page.index.favoritesOnly')} />
      <SortControl label={t('sort.label')} newestLabel={t('sort.newest')} alphaLabel={t('sort.alpha')} quickestLabel={t('sort.quickest')} />
    </div>
  </div>
  <div class="mb-8">
    <TimeFilter label={t('filter.time.label')} anyLabel={t('filter.time.any')} under30Label={t('filter.time.under30')} under60Label={t('filter.time.under60')} />
  </div>

  <div id="recipe-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    {recipesWithSlug.map((recipe, i) => (
      <RecipeCard
        title={recipe.data.title}
        tags={recipe.data.tags}
        prepTime={recipe.data.prepTime}
        cookTime={recipe.data.cookTime}
        prepLabel={t('page.recipe.prep')}
        cookLabel={t('page.recipe.cook')}
        favoriteLabel={t('page.recipe.favorite')}
        slug={recipe.slug}
        image={recipe.data.image}
        author={recipe.data.author}
        difficultyLabel={recipe.data.difficulty ? t(`difficulty.${recipe.data.difficulty}`) : undefined}
        ingredients={ingredientNames(recipe.data.ingredients)}
        baseRecipePath="/de/recipes/"
        loading={i < EAGER_CARD_COUNT ? 'eager' : 'lazy'}
      />
    ))}
    <div id="recipe-grid-empty" class="hidden col-span-full py-16 text-center">
      <svg class="mx-auto w-12 h-12 mb-3 text-gray-300 dark:text-gray-600" aria-hidden="true"><use href="#icon-search"/></svg>
      <p class="text-base font-medium text-gray-700 dark:text-gray-200">{t('search.noResults')}</p>
    </div>
  </div>
</BaseLayout>
