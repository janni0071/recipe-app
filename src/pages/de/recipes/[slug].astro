---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import IngredientList from '../../../components/IngredientList.astro';
import RecipeCard from '../../../components/RecipeCard.astro';
import { Image } from 'astro:assets';
import { getCollection, type CollectionEntry, render } from 'astro:content';
import { useTranslations } from '../../../utils/i18n';
import { getSimilarRecipes } from '../../../utils/similar';

type StaticPath = {
  params: { slug: string };
  props: { recipe: CollectionEntry<'recipes'> };
};

export async function getStaticPaths(): Promise<StaticPath[]> {
  const recipes = await getCollection('recipes');
  return recipes
    .filter((recipe: CollectionEntry<'recipes'>) => recipe.id.startsWith('de/'))
    .map((recipe: CollectionEntry<'recipes'>) => {
      const slug = recipe.id.replace(/^de\//, '').replace(/\.md$/, '');
      return {
        params: { slug },
        props: { recipe },
      };
    });
}

type Props = {
  recipe: CollectionEntry<'recipes'>;
};

const { recipe } = Astro.props as Props;
const { Content } = await render(recipe);
const t = useTranslations('de');

const slug = recipe.id.replace(/^de\//, '').replace(/\.md$/, '');
const allRecipes = await getCollection('recipes');
const normalizeId = (id: string) => id.replace(/\.md$/, '');
const hasEN = allRecipes.some((r) => normalizeId(r.id) === slug);
const hasFR = allRecipes.some((r) => normalizeId(r.id) === `fr/${slug}`);
const localeUrls = {
  en: hasEN ? `/recipes/${slug}` : '/',
  de: `/de/recipes/${slug}`,
  fr: hasFR ? `/fr/recipes/${slug}` : '/fr/',
};

const localeRecipes = allRecipes.filter((r) => r.id.startsWith('de/'));
const similarRecipes = getSimilarRecipes(recipe, localeRecipes).map((r) => ({
  ...r,
  slug: r.id.replace(/^de\//, '').replace(/\.md$/, ''),
}));
---
<BaseLayout title={recipe.data.title} localeUrls={localeUrls}>
  <article class="max-w-3xl mx-auto">
    {recipe.data.image ? (
      <Image
        src={recipe.data.image}
        alt={recipe.data.title}
        width={900}
        height={400}
        format="webp"
        loading="eager"
        fetchpriority="high"
        decoding="async"
        class="w-full h-64 object-cover rounded-xl mb-6"
        transition:name={`recipe-image-${slug}`}
      />
    ) : (
      <div class="w-full h-64 bg-gray-200 rounded-xl mb-6 dark:bg-gray-700" />
    )}
    <h1 class="text-4xl font-bold mb-4 dark:text-white" transition:name={`recipe-title-${slug}`}>{recipe.data.title}</h1>

    <div class="flex flex-wrap gap-4 text-gray-600 mb-6 pb-4 border-b dark:text-gray-400 dark:border-gray-700">
      <span>🕒 {t('page.recipe.prep')}: {recipe.data.prepTime}</span>
      <span>🔥 {t('page.recipe.cook')}: {recipe.data.cookTime}</span>
      <span class="capitalize">🍽️ {t('page.recipe.servings')}: {recipe.data.servings}</span>
    </div>

    <div class="flex flex-wrap gap-2 mb-8">
      {recipe.data.tags.map((tag: string) => (
        <a
          href={`/de/tags/${tag}`}
          class="bg-gray-100 px-3 py-1 rounded-full text-sm hover:bg-gray-200 dark:bg-gray-700 dark:text-gray-200 dark:hover:bg-gray-600"
        >
          #{tag}
        </a>
      ))}
    </div>

    <div class="prose max-w-none">
      <IngredientList
        heading={t('page.recipe.ingredients')}
        groups={recipe.data.ingredients}
        servings={recipe.data.servings}
        servingsLabel={t('page.recipe.servings')}
      />
      <Content />
    </div>

    {similarRecipes.length > 0 && (
      <div class="mt-12 border-t pt-8 dark:border-gray-700">
        <h2 class="text-2xl font-semibold mb-4 dark:text-white">{t('page.recipe.similar')}</h2>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
          {similarRecipes.map((similar) => (
            <RecipeCard
              title={similar.data.title}
              tags={similar.data.tags}
              prepTime={similar.data.prepTime}
              cookTime={similar.data.cookTime}
              prepLabel={t('page.recipe.prep')}
              cookLabel={t('page.recipe.cook')}
              slug={similar.slug}
              image={similar.data.image}
              baseRecipePath="/de/recipes/"
              loading="lazy"
            />
          ))}
        </div>
      </div>
    )}
  </article>
</BaseLayout>
