---
import BaseLayout from '../layouts/BaseLayout.astro';
import RecipeCard from '../components/RecipeCard.astro';
import Search from '../components/SearchBar.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

const allRecipes = await getCollection('recipes');
const sortedRecipes = allRecipes.sort((a: CollectionEntry<'recipes'>, b: CollectionEntry<'recipes'>) =>
  b.data.date.getTime() - a.data.date.getTime()
);

// Prepare recipes with slugs pre-computed
const recipesWithSlug = sortedRecipes.map((recipe: CollectionEntry<'recipes'>) => ({
  ...recipe,
  slug: recipe.id.replace(/\.md$/, '')
}));
---
<BaseLayout title="All Recipes">
  <h1 class="text-3xl font-bold mb-6">Our Recipe Collection 🧑‍🍳</h1>

  <!-- Add margin-bottom to separate search from recipe grid -->
  <div class="mb-8">
    <Search />
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    {recipesWithSlug.map((recipe) => (
      <RecipeCard
        title={recipe.data.title}
        tags={recipe.data.tags}
        prepTime={recipe.data.prepTime}
        cookTime={recipe.data.cookTime}
        slug={recipe.slug}
        image={recipe.data.image}
      />
    ))}
  </div>
</BaseLayout>
