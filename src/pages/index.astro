---
import BaseLayout from '../layouts/BaseLayout.astro';
import RecipeCard from '../components/RecipeCard.astro';
import FavoritesFilterToggle from '../components/FavoritesFilterToggle.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { useTranslations, getIndexHeadingParts } from '../utils/i18n';

const t = useTranslations('en');
const heading = getIndexHeadingParts('en');
const allRecipes = await getCollection('recipes');
const sortedRecipes = allRecipes
  .filter((r: CollectionEntry<'recipes'>) => !r.id.match(/^(de|fr)\//))
  .sort((a: CollectionEntry<'recipes'>, b: CollectionEntry<'recipes'>) =>
  b.data.date.getTime() - a.data.date.getTime()
);

// Prepare recipes with slugs pre-computed
const recipesWithSlug = sortedRecipes.map((recipe: CollectionEntry<'recipes'>) => ({
  ...recipe,
  slug: recipe.id.replace(/\.md$/, '')
}));
---
<BaseLayout title={t('page.index.title')}>
  <h1 class="text-3xl font-bold mb-6">{heading.before}<span class="text-pink-500 dark:text-pink-400">{heading.names}</span>{heading.after}</h1>

  <div class="mb-8 flex justify-end">
    <FavoritesFilterToggle label={t('page.index.favoritesOnly')} />
  </div>

  <div id="recipe-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    {recipesWithSlug.map((recipe, i) => (
      <RecipeCard
        title={recipe.data.title}
        tags={recipe.data.tags}
        prepTime={recipe.data.prepTime}
        cookTime={recipe.data.cookTime}
        prepLabel={t('page.recipe.prep')}
        cookLabel={t('page.recipe.cook')}
        favoriteLabel={t('page.recipe.favorite')}
        slug={recipe.slug}
        image={recipe.data.image}
        author={recipe.data.author}
        loading={i === 0 ? 'eager' : 'lazy'}
      />
    ))}
  </div>
  <p id="recipe-grid-empty" class="hidden text-gray-500 dark:text-gray-400">{t('search.noResults')}</p>
</BaseLayout>
