---
import BaseLayout from '../../layouts/BaseLayout.astro';
import IngredientList from '../../components/IngredientList.astro';
import RecipeCard from '../../components/RecipeCard.astro';
import ShareButton from '../../components/ShareButton.astro';
import PrintButton from '../../components/PrintButton.astro';
import FavoriteButton from '../../components/FavoriteButton.astro';
import { Image, getImage } from 'astro:assets';
import { getCollection, type CollectionEntry, render } from 'astro:content';
import { useTranslations } from '../../utils/i18n';
import { getSimilarRecipes } from '../../utils/similar';
import { buildRecipeJsonLd } from '../../utils/recipeSchema';

type StaticPath = {
  params: { slug: string };
  props: { recipe: CollectionEntry<'recipes'> };
};

export async function getStaticPaths(): Promise<StaticPath[]> {
  const recipes = await getCollection('recipes');
  return recipes
    .filter((recipe: CollectionEntry<'recipes'>) => !recipe.id.match(/^(de|fr)\//))
    .map((recipe: CollectionEntry<'recipes'>) => {
      const slug = recipe.id.replace(/\.md$/, '');
      return {
        params: { slug },
        props: { recipe },
      };
    });
}

type Props = {
  recipe: CollectionEntry<'recipes'>;
};

const { recipe } = Astro.props as Props;
const { Content } = await render(recipe);
const t = useTranslations('en');

const slug = recipe.id.replace(/\.md$/, '');
const allRecipes = await getCollection('recipes');
const normalizeId = (id: string) => id.replace(/\.md$/, '');
const hasDE = allRecipes.some((r) => normalizeId(r.id) === `de/${slug}`);
const hasFR = allRecipes.some((r) => normalizeId(r.id) === `fr/${slug}`);
const localeUrls = {
  en: `/recipes/${slug}`,
  de: hasDE ? `/de/recipes/${slug}` : '/de/',
  fr: hasFR ? `/fr/recipes/${slug}` : '/fr/',
};

const localeRecipes = allRecipes.filter((r) => !r.id.match(/^(de|fr)\//));
const similarRecipes = getSimilarRecipes(recipe, localeRecipes).map((r) => ({
  ...r,
  slug: r.id.replace(/\.md$/, ''),
}));

const description = `${t('page.recipe.prep')}: ${recipe.data.prepTime} · ${t('page.recipe.cook')}: ${recipe.data.cookTime}`;
const ogImage = recipe.data.image
  ? await getImage({ src: recipe.data.image, width: 900, height: 400, format: 'webp', quality: 75 })
  : undefined;

const jsonLd = buildRecipeJsonLd({
  name: recipe.data.title,
  description,
  imageUrl: ogImage ? new URL(ogImage.src, Astro.site).toString() : undefined,
  authorName: recipe.data.author,
  datePublished: recipe.data.date,
  prepTime: recipe.data.prepTime,
  cookTime: recipe.data.cookTime,
  servings: recipe.data.servings,
  ingredientGroups: recipe.data.ingredients,
  stepsMarkdownBody: recipe.body ?? '',
  pageUrl: new URL(Astro.url.pathname, Astro.site).toString(),
  locale: 'en',
});
---
<BaseLayout title={recipe.data.title} description={description} image={ogImage} localeUrls={localeUrls}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <article class="max-w-3xl mx-auto">
    {recipe.data.image ? (
      <Image
        src={recipe.data.image}
        alt={recipe.data.title}
        width={900}
        height={400}
        format="webp"
        quality={75}
        loading="eager"
        fetchpriority="high"
        decoding="async"
        class="print:hidden w-full h-64 object-cover rounded-xl mb-6 bg-gray-200 dark:bg-gray-700"
        transition:name={`recipe-image-${slug}`}
        transition:persist
      />
    ) : (
      <div class="print:hidden w-full h-64 bg-gray-200 rounded-xl mb-6 dark:bg-gray-700" />
    )}
    <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between sm:gap-4 mb-4">
      <h1 class="text-4xl font-bold dark:text-white min-w-0 sm:flex-1 break-words" transition:name={`recipe-title-${slug}`}>{recipe.data.title}</h1>
      <div class="print:hidden flex items-center gap-2 self-end sm:self-auto sm:flex-shrink-0">
        <FavoriteButton slug={slug} label={t('page.recipe.favorite')} />
        <ShareButton title={recipe.data.title} label={t('page.recipe.share')} copiedLabel={t('page.recipe.linkCopied')} />
        <PrintButton label={t('page.recipe.print')} />
      </div>
    </div>

    <div class="flex flex-wrap gap-4 text-gray-600 mb-6 pb-4 border-b dark:text-gray-400 dark:border-gray-700">
      <span>🕒 {t('page.recipe.prep')}: {recipe.data.prepTime}</span>
      <span>🔥 {t('page.recipe.cook')}: {recipe.data.cookTime}</span>
      <span class="capitalize">🍽️ {t('page.recipe.servings')}: {recipe.data.servings}</span>
    </div>

    <div class="print:hidden flex flex-wrap gap-2 mb-8">
      {recipe.data.tags.map((tag: string) => (
        <a
          href={`/tags/${tag}`}
          class="bg-gray-100 px-3 py-1 rounded-full text-sm hover:bg-gray-200 dark:bg-gray-700 dark:text-gray-200 dark:hover:bg-gray-600"
        >
          #{tag}
        </a>
      ))}
    </div>

    <div class="prose max-w-none">
      <IngredientList
        heading={t('page.recipe.ingredients')}
        groups={recipe.data.ingredients}
        servings={recipe.data.servings}
        servingsLabel={t('page.recipe.servings')}
      />
      <Content />
    </div>

    {similarRecipes.length > 0 && (
      <div class="print:hidden mt-12 border-t pt-8 dark:border-gray-700">
        <h2 class="text-2xl font-semibold mb-4 dark:text-white">{t('page.recipe.similar')}</h2>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
          {similarRecipes.map((similar) => (
            <RecipeCard
              title={similar.data.title}
              tags={similar.data.tags}
              prepTime={similar.data.prepTime}
              cookTime={similar.data.cookTime}
              prepLabel={t('page.recipe.prep')}
              cookLabel={t('page.recipe.cook')}
              favoriteLabel={t('page.recipe.favorite')}
              slug={similar.slug}
              image={similar.data.image}
              loading="lazy"
            />
          ))}
        </div>
      </div>
    )}
  </article>
</BaseLayout>
