---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths(): Promise<{ params: { slug: string }; props: { recipe: CollectionEntry<'recipes'> } }[]> {
  const recipes = await getCollection('recipes');
  return recipes.map((recipe: CollectionEntry<'recipes'>) => ({
    params: { slug: recipe.slug },
    props: { recipe },
  }));
}

type Props = {
  recipe: CollectionEntry<'recipes'>;
};

const { recipe } = Astro.props as Props;
const { Content } = await recipe.render();
---
<BaseLayout title={recipe.data.title}>
  <article class="max-w-3xl mx-auto">
    <img
      src={recipe.data.image || '/default-recipe.jpg'}
      alt={recipe.data.title}
      class="w-full h-64 object-cover rounded-xl mb-6"
    />
    <h1 class="text-4xl font-bold mb-4">{recipe.data.title}</h1>

    <div class="flex flex-wrap gap-4 text-gray-600 mb-6 pb-4 border-b">
      <span>🕒 Prep: {recipe.data.prepTime}</span>
      <span>🔥 Cook: {recipe.data.cookTime}</span>
      <span>🍽️ Serves: {recipe.data.servings}</span>
    </div>

    <div class="flex flex-wrap gap-2 mb-8">
      {recipe.data.tags.map((tag: string) => (
        <a href={`/tags/${tag}`} class="bg-gray-100 px-3 py-1 rounded-full text-sm hover:bg-gray-200">#{tag}</a>
      ))}
    </div>

    <div class="prose prose-rose max-w-none">
      <Content />
    </div>
  </article>
</BaseLayout>
